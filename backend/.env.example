# =============================================================================
# ChatSphere Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED]
# Optional variables have sensible defaults
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# [REQUIRED] MongoDB connection string
# Local: mongodb://localhost:27017/chatsphere
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/chatsphere
MONGO_URI=mongodb://localhost:27017/chatsphere

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# [REQUIRED] JWT secret for access tokens (use a long random string)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_random_secret_at_least_32_chars

# [REQUIRED] JWT secret for refresh tokens (different from access secret)
JWT_REFRESH_SECRET=replace_with_different_random_secret

# Access token TTL (default: 15m)
# JWT_ACCESS_EXPIRY=15m

# Refresh token TTL (default: 7d)
# JWT_REFRESH_EXPIRY=7d

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Server port (default: 3000)
PORT=3000

# [REQUIRED] Frontend URL for CORS
CLIENT_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Google OAuth (Optional)
# -----------------------------------------------------------------------------

# Google OAuth credentials from https://console.cloud.google.com
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# -----------------------------------------------------------------------------
# Email (Optional - for password reset)
# -----------------------------------------------------------------------------

# SMTP configuration for Nodemailer
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=ChatSphere <noreply@chatsphere.app>

# -----------------------------------------------------------------------------
# AI Providers (at least one required for AI features)
# -----------------------------------------------------------------------------

# OpenRouter - Multi-provider gateway (recommended)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-5.4-mini

# Default AI model (used when user selects "auto")
DEFAULT_AI_MODEL=openai/gpt-5.4-mini

# Google Gemini Direct
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# xAI Grok Direct
# Get key: https://console.x.ai
GROK_API_KEY=
# GROK_MODEL=grok-2-latest

# Groq - Fast inference
# Get key: https://console.groq.com
GROQ_API_KEY=

# Together AI - Open-source models
# Get key: https://api.together.xyz
TOGETHER_API_KEY=

# Hugging Face
# Get key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
# HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct:cerebras

# -----------------------------------------------------------------------------
# AI Configuration (Optional - defaults are fine for most setups)
# -----------------------------------------------------------------------------

# Max tokens for chat responses (default: 1200)
# AI_CHAT_MAX_COMPLETION_TOKENS=1200

# Max tokens for JSON extraction (default: 400)
# AI_JSON_MAX_COMPLETION_TOKENS=400

# Max fallback attempts per request (default: 6)
# AI_FALLBACK_MODEL_LIMIT=6

# Model catalog refresh interval in ms (default: 1800000 = 30min)
# MODEL_CATALOG_TTL_MS=1800000

# -----------------------------------------------------------------------------
# Message Configuration (Optional)
# -----------------------------------------------------------------------------

# Edit window for messages in minutes (default: 15)
# MESSAGE_EDIT_WINDOW_MINUTES=15

# AI bot name in group chats (default: Gemini)
# GEMINI_GROUP_BOT_NAME=Gemini

# -----------------------------------------------------------------------------
# Rate Limiting (Optional)
# -----------------------------------------------------------------------------

# Rate limit window in ms (default: 900000 = 15min)
# RATE_LIMIT_WINDOW_MS=900000

# Max requests per window (default: 100)
# RATE_LIMIT_MAX_REQUESTS=100
